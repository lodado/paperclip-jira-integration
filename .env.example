# HTTP webhook route removed — this deployment is polling-only (see README).
# Poll: GET/POST /integrations/jira/poll — Bearer auth (Vercel Cron uses CRON_SECRET)
# CRON_SECRET=
# JIRA_POLL_SECRET=
# Planner task create API: POST /integrations/jira/tasks
# JIRA_PLANNER_SECRET=

# Jira REST (required for polling — create API token under Atlassian account security)
JIRA_ATLASSIAN_EMAIL=
JIRA_ATLASSIAN_API_TOKEN=
# ATLASSIAN_EMAIL=
# JIRA_API_TOKEN=

# Optional extra JQL appended after time clause, e.g. AND project = PROJ
# JIRA_POLL_JQL=AND project = PROJ

# Local cron helper scripts/jira-poll-local-cron.sh — plain JQL (no URL encoding in crontab)
# JIRA_POLL_CRON_BASE_URL=http://127.0.0.1:9997/integrations/jira/poll
# JIRA_POLL_CRON_JQL=assignee = currentUser() AND project = MYPROJ
# JIRA_POLL_CRON_LOG=/Users/you/Library/Logs/papaclip-jira-poll.log

# Paperclip API (required for sync)
# JIRA_* names take precedence over PAPERCLIP_* if both are set
JIRA_PAPERCLIP_API_URL=
JIRA_PAPERCLIP_API_KEY=
JIRA_PAPERCLIP_COMPANY_ID=
# PAPERCLIP_API_URL=
# PAPERCLIP_API_KEY=
# PAPERCLIP_COMPANY_ID=

# Atlassian (required)
JIRA_CLOUD_ID=

# Optional: Paperclip project for new/updated issues
# JIRA_DEFAULT_PROJECT_ID=
# JIRA_PROJECT_MAPPING_JSON={"10001":"paperclip-project-id","PROJ":"paperclip-project-id"}

# Optional: Paperclip agent id assigned on **new** issues only (webhook/poll create path)
# JIRA_PAPERCLIP_NEW_ISSUE_ASSIGNEE_AGENT_ID=
# PAPERCLIP_NEW_ISSUE_ASSIGNEE_AGENT_ID=
# Optional: fallback agent lookup by `urlKey` when no assignee id is set
# Default when unset: jira-controller
# Set empty string to disable URL-key fallback lookup
# JIRA_PAPERCLIP_NEW_ISSUE_ASSIGNEE_AGENT_URL_KEY=
# PAPERCLIP_NEW_ISSUE_ASSIGNEE_AGENT_URL_KEY=

# Optional: persist state outside default .paperclip/integrations/jira-storage.sqlite
# JIRA_STORAGE_FILE=

# Optional: Planner task create defaults
# JIRA_PLANNER_DEFAULT_PROJECT_KEY=MAY
# JIRA_PLANNER_DEFAULT_ISSUE_TYPE=Task
# Optional: default Jira assignee (Cloud account id). Overrides ASSIGN_TO_API_USER when set.
# JIRA_PLANNER_DEFAULT_ASSIGNEE_ACCOUNT_ID=
# When true or 1, planner calls Jira GET /myself and sets assignee to the API token owner
# (skips the extra call if assignee already set via body or DEFAULT_ASSIGNEE_ACCOUNT_ID).
JIRA_PLANNER_ASSIGN_TO_API_USER=1
# Optional: override Atlassian API base URL for tests/mocks
# JIRA_ATLASSIAN_API_BASE_URL=https://api.atlassian.com

# Optional: protect the Next.js web UI (/) with a console password + signed cookie session.
# Integration routes under /integrations/* stay on Bearer auth only.
# CONSOLE_LOGIN_PASSWORD=
# CONSOLE_SESSION_SECRET=
