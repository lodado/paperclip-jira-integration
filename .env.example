# Webhook (required for POST /integrations/jira/webhook)
JIRA_WEBHOOK_SECRET=

# Paperclip API (required for sync)
# JIRA_* names take precedence over PAPERCLIP_* if both are set
JIRA_PAPERCLIP_API_URL=
JIRA_PAPERCLIP_API_KEY=
JIRA_PAPERCLIP_COMPANY_ID=
# PAPERCLIP_API_URL=
# PAPERCLIP_API_KEY=
# PAPERCLIP_COMPANY_ID=

# Atlassian (required)
JIRA_CLOUD_ID=

# Optional: Paperclip project for new/updated issues
# JIRA_DEFAULT_PROJECT_ID=
# JIRA_PROJECT_MAPPING_JSON={"10001":"paperclip-project-id","PROJ":"paperclip-project-id"}

# Optional: persist state outside default .paperclip/integrations/jira-storage.json
# JIRA_STORAGE_FILE=
