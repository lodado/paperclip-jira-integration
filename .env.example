# HTTP webhook route removed — this deployment is polling-only (see README).
# Poll: GET/POST /integrations/jira/poll — Bearer auth (Vercel Cron uses CRON_SECRET)
# CRON_SECRET=
# JIRA_POLL_SECRET=

# Jira REST (required for polling — create API token under Atlassian account security)
JIRA_ATLASSIAN_EMAIL=
JIRA_ATLASSIAN_API_TOKEN=
# ATLASSIAN_EMAIL=
# JIRA_API_TOKEN=

# Default lookback window for JQL `updated >= -Nm` (overlap vs 5m cron; default 10)
# JIRA_POLL_LOOKBACK_MINUTES=10

# Optional extra JQL appended after time clause, e.g. AND project = PROJ
# JIRA_POLL_JQL=AND project = PROJ

# Paperclip API (required for sync)
# JIRA_* names take precedence over PAPERCLIP_* if both are set
JIRA_PAPERCLIP_API_URL=
JIRA_PAPERCLIP_API_KEY=
JIRA_PAPERCLIP_COMPANY_ID=
# PAPERCLIP_API_URL=
# PAPERCLIP_API_KEY=
# PAPERCLIP_COMPANY_ID=

# Atlassian (required)
JIRA_CLOUD_ID=

# Optional: Paperclip project for new/updated issues
# JIRA_DEFAULT_PROJECT_ID=
# JIRA_PROJECT_MAPPING_JSON={"10001":"paperclip-project-id","PROJ":"paperclip-project-id"}

# Optional: Paperclip agent id assigned on **new** issues only (webhook/poll create path)
# JIRA_PAPERCLIP_NEW_ISSUE_ASSIGNEE_AGENT_ID=
# PAPERCLIP_NEW_ISSUE_ASSIGNEE_AGENT_ID=
# Optional: fallback agent lookup by `urlKey` when no assignee id is set
# Default when unset: jira-controller
# Set empty string to disable URL-key fallback lookup
# JIRA_PAPERCLIP_NEW_ISSUE_ASSIGNEE_AGENT_URL_KEY=
# PAPERCLIP_NEW_ISSUE_ASSIGNEE_AGENT_URL_KEY=

# Optional: persist state outside default .paperclip/integrations/jira-storage.json
# JIRA_STORAGE_FILE=
